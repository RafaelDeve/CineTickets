@model Proyecto.Domain.Entities.Pelicula
@{
    ViewData["Title"] = "Detalle de Película";
}

<h1>@Model.Titulo</h1>
<p>@Model.Descripcion</p>
<p>Duración: @Model.Duracion</p>
<a href="/Peliculas/Proyecciones?peliculaId=@Model.PeliculaId">Ver Proyecciones</a>
<a href="/Peliculas/Editar?id=@Model.PeliculaId">Editar Pelicula</a>
<form method="post" action="/Peliculas/Eliminar">
    <input type="hidden" name="id" value="@Model.PeliculaId" />
    <button type="submit" class="btn btn-danger">Eliminar Película</button>
</form>